<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="zTransform" />
		<Option pch_mode="0" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin\Debug\zSlangInterpreter" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj\Debug\" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Option projectLinkerOptionsRelation="2" />
				<Compiler>
					<Add option="-g" />
					<Add option="-D__DEBUG__" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="$(#wx)\lib\gcc_dll\mswu" />
				</ResourceCompiler>
				<Linker>
					<Add directory="$(#wx)\lib\gcc_dll" />
					<Add directory="$(#boost.lib)" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin\Release\zSlangInterpreter" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj\Release\" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Option projectLinkerOptionsRelation="2" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="$(#wx)\lib\gcc_dll\mswu" />
				</ResourceCompiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-pipe" />
			<Add option="-mthreads" />
			<Add option='[[if (PLATFORM == PLATFORM_MSW &amp;&amp; (GetCompilerFactory().GetCompilerVersionString(_T(&quot;gcc&quot;)) &gt;= _T(&quot;4.0.0&quot;))) print(_T(&quot;-Wno-attributes&quot;));]]' />
			<Add option="-Werror" />
			<Add option="-Wswitch" />
			<Add directory="$(#boost.include)" />
			<Add directory="src\grammarRules" />
			<Add directory="." />
			<Add directory=".\include" />
		</Compiler>
		<ResourceCompiler>
			<Add directory="$(#wx)\include" />
		</ResourceCompiler>
		<Linker>
			<Add option="-mthreads" />
			<Add option="-Wl,--stack,16777216" />
			<Add option="-static-libgcc" />
			<Add option="-static-libstdc++" />
			<Add option="-static" />
			<Add library="libboost_random-mgw46-s-1_50.a" />
			<Add library="libboost_regex-mgw46-s-1_50.a" />
			<Add directory="$(#boost.lib)" />
			<Add directory="$(#wx.lib)" />
		</Linker>
		<Unit filename="include\Grammar.h" />
		<Unit filename="include\TCode_Printer.h" />
		<Unit filename="include\TExternals.h" />
		<Unit filename="include\cInterpreter.h" />
